---
interface Props {
  title: string;
  description?: string;
  lang: "ru" | "en";
}

const {
  title,
  description = "Personal website about math, programming, and game development.",
  lang,
} = Astro.props;

const isRu = lang === "ru";

const nav = isRu
  ? {
      home: "Главная",
      about: "Обо мне",
      math: "Математика",
      programming: "Программирование",
      game: "Игра",
      blog: "Блог",
      projects: "Проекты",
      shop: "Мерч",
      switchLang: "EN",
      switchHref: "/en/",
      prefix: "/ru",
      tagline: "Математика · Код · Игры",
    }
  : {
      home: "Home",
      about: "About",
      math: "Math",
      programming: "Programming",
      game: "Game",
      blog: "Blog",
      projects: "Projects",
      shop: "Merch",
      switchLang: "RU",
      switchHref: "/ru/",
      prefix: "/en",
      tagline: "Math · Code · Games",
    };
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <header>
      <a href={`${nav.prefix}/`}>&lt;(.____.)&gt;</a>

      <nav>
        <a href={`${nav.prefix}/`}>{nav.home}</a>
        <a href={`${nav.prefix}/about/`}>{nav.about}</a>
        <a href={`${nav.prefix}/math/`}>{nav.math}</a>
        <a href={`${nav.prefix}/programming/`}>{nav.programming}</a>
        <a href={`${nav.prefix}/game/`}>{nav.game}</a>
        <a href={`${nav.prefix}/blog/`}>{nav.blog}</a>
        <a href={`${nav.prefix}/projects/`}>{nav.projects}</a>
        <a href={`${nav.prefix}/shop/`}>{nav.shop}</a>
        <a href={nav.switchHref}>{nav.switchLang}</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&lt;(.____.)&gt; — {nav.tagline}</p>
      <p>© 2026</p>
    </footer>
  </body>
</html>