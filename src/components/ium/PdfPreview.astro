---
interface Props {
  title: string;
  src?: string;
  downloadLabel: string;
  emptyLabel: string;
}

const { title, src, downloadLabel, emptyLabel } = Astro.props;
const hasPdf = typeof src === "string" && src.length > 0;
---

<section class="pdf-block">
  <h2>{title}</h2>

  {hasPdf ? (
    <div class="pdf-wrapper">
      <object data={src} type="application/pdf" class="pdf-object">
        <p>
          Предпросмотр PDF недоступен.
          <a href={src} target="_blank" rel="noreferrer">Открыть PDF</a>
        </p>
      </object>

      <p>
        <a class="download" href={src} download>
          {downloadLabel}
        </a>
      </p>
    </div>
  ) : (
    <p class="empty">{emptyLabel}</p>
  )}
</section>

<style>
  .pdf-block {
    margin-top: var(--space-xl);
  }

  .pdf-wrapper {
    display: grid;
    gap: var(--space-md);
  }

  .pdf-object {
    width: 100%;
    height: 720px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
  }

  .download {
    display: inline-flex;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-card);
    text-decoration: none;
  }

  .download:hover {
    background: var(--color-header-hover);
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(2px);
  }

  .empty {
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .pdf-object {
      height: 520px;
    }
  }
</style>