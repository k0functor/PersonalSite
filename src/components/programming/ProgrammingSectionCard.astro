---
import type { ProgrammingSection, Lang } from "../../lib/programming/catalog";
import { getSectionDescription, getSectionTitle } from "../../lib/programming/catalog";

interface Props {
  section: ProgrammingSection;
  lang: Lang;
}

const { section, lang } = Astro.props;
const title = getSectionTitle(section, lang);
const description = getSectionDescription(section, lang);
---

<a class="section-card" href={`/${lang}/programming/${section.id}/`}>
  <h2>{title}</h2>
  <p>{description}</p>
</a>

<style>
  .section-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    color: inherit;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .section-card:hover {
    border-color: var(--color-accent);
    transform: translateY(2px);
    box-shadow: var(--shadow-soft);
  }

  h2 {
    margin-top: 0;
  }

  p {
    margin-bottom: 0;
    color: var(--color-muted);
  }
</style>
