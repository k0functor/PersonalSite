---
import type { MathBook } from "../data/mathBooks";

interface Props {
  book: MathBook;
  lang?: "ru" | "en";
}

const { book, lang = "ru" } = Astro.props;

const statusLabels = {
  ru: {
    read: "прочитал",
    reading: "читаю",
    planned: "планирую",
    paused: "отложил",
    reference: "справочник",
  },
  en: {
    read: "read",
    reading: "reading",
    planned: "planned",
    paused: "paused",
    reference: "reference",
  },
};

const levelLabels = {
  ru: {
    basic: "базовый",
    intermediate: "средний",
    advanced: "продвинутый",
  },
  en: {
    basic: "basic",
    intermediate: "intermediate",
    advanced: "advanced",
  },
};

const fieldLabels = {
  ru: {
    area: "Область",
    level: "Уровень",
    language: "Язык",
  },
  en: {
    area: "Area",
    level: "Level",
    language: "Language",
  },
};
---

<article class="book-card">
  <div class="top">
    <h3>{book.title}</h3>
    <span>{statusLabels[lang][book.status]}</span>
  </div>

  <p class="author">{book.author}</p>

  <dl>
    <div>
      <dt>{fieldLabels[lang].area}</dt>
      <dd>{book.area}</dd>
    </div>

    <div>
      <dt>{fieldLabels[lang].level}</dt>
      <dd>{levelLabels[lang][book.level]}</dd>
    </div>

    <div>
      <dt>{fieldLabels[lang].language}</dt>
      <dd>{book.language.toUpperCase()}</dd>
    </div>
  </dl>

  <p>{book.comment}</p>
</article>

<style>
  .book-card {
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
  }

  .top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    align-items: baseline;
  }

  h3 {
    margin: 0;
  }

  .top span {
    color: var(--color-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .author {
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  dl {
    display: grid;
    gap: 0.35rem;
    margin: var(--space-md) 0;
  }

  dl div {
    display: flex;
    gap: 0.5rem;
  }

  dt {
    color: var(--color-muted);
  }

  dd {
    margin: 0;
  }
</style>