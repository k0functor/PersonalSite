---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"math-ium">;
  lang?: "ru" | "en";
}

const { entry, lang = "ru" } = Astro.props;
const { title, description, course, sheetNumber, status, solved, total } = entry.data;

const slug = entry.data.slug ?? entry.id;

const statusLabels = {
  ru: {
    "not-started": "не начат",
    "in-progress": "в процессе",
    "partly-solved": "решён частично",
    solved: "решён",
    submitted: "сдан",
    "needs-rewrite": "нужно переписать",
  },
  en: {
    "not-started": "not started",
    "in-progress": "in progress",
    "partly-solved": "partly solved",
    solved: "solved",
    submitted: "submitted",
    "needs-rewrite": "needs rewrite",
  },
};

const sheetLabel = lang === "ru" ? "листок" : "sheet";
---

<a class="sheet-card" href={`/${lang}/math/ium/${slug}/`}>
  <p class="eyebrow">{course} / {sheetLabel} {sheetNumber}</p>
  <h3>{title}</h3>
  <p>{description}</p>

  <div class="meta">
    <span>{statusLabels[lang][status]}</span>
    <span>{solved} / {total}</span>
  </div>
</a>

<style>
  .sheet-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    text-decoration: none;
  }

  .sheet-card:hover {
    border-color: var(--color-accent);
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  h3 {
    margin-top: 0;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-md);
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>