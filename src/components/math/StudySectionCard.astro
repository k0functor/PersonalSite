---
interface Section {
  id: string;
  titleRu: string;
  titleEn: string;
  descriptionRu: string;
  descriptionEn: string;
  order: number;
}

interface Props {
  section: Section;
  lang: "ru" | "en";
}

const { section, lang } = Astro.props;
const title = lang === "ru" ? section.titleRu : section.titleEn;
const description = lang === "ru" ? section.descriptionRu : section.descriptionEn;
---

<a class="section-card" href={`/${lang}/math/study/${section.id}/`}>
  <h3>{title}</h3>
  <p>{description}</p>
</a>

<style>
  .section-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    color: inherit;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .section-card:hover {
    border-color: var(--color-accent);
    transform: translateY(2px);
    box-shadow: var(--shadow-soft);
  }

  h3 {
    margin-top: 0;
  }

  p {
    margin-bottom: 0;
    color: var(--color-muted);
  }
</style>
