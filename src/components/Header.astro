---
import {
  routes,
  getLocalizedPath,
  getLanguageSwitchPath,
  type Lang,
} from "../config/navigation";
import { getDictionary } from "../i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDictionary(lang);

const otherLang = lang === "ru" ? "en" : "ru";
const otherLangLabel = lang === "ru" ? "EN" : "RU";

const switchHref = getLanguageSwitchPath(Astro.url.pathname, otherLang);
---

<header class="site-header">
  <div class="inner">
    <a class="logo" href={getLocalizedPath(lang)}>
      &lt;(.____.)&gt;
    </a>

    <nav class="nav" aria-label="Main navigation">
      {routes.map((route) => (
        <a href={getLocalizedPath(lang, route.href)}>
          {t.nav[route.key]}
        </a>
      ))}

      <a class="lang" href={switchHref}>
        {otherLangLabel}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 0;
  }

  .inner {
    width: min(100% - 2rem, var(--max-width));
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 var(--radius) var(--radius);
    background: var(--color-header);
    box-shadow: 0 2px 10px rgba(24, 22, 18, 0.04);
  }

  .logo {
    font-family: var(--font-mono);
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.4rem 0.65rem;
    border: 1px solid transparent;
    border-radius: 4px;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .logo:hover {
    background: var(--color-header-hover);
    border-color: var(--color-border);
    color: var(--color-accent);
    transform: translateY(2px);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.4rem;
    font-size: 0.95rem;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid transparent;
    border-radius: 4px;
    text-decoration: none;
    background: transparent;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }

  .nav a:hover {
    background: var(--color-header-hover);
    border-color: var(--color-border);
    color: var(--color-accent);
    transform: translateY(2px);
  }

  .lang {
    font-weight: 700;
    border-color: var(--color-border) !important;
  }

  .lang:hover {
    border-color: var(--color-accent) !important;
  }

  @media (max-width: 760px) {
    .inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav {
      justify-content: flex-start;
    }
  }
</style>