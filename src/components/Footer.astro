---
import type { Lang } from "../config/navigation";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const labels = {
  ru: {
    telegram: "Telegram",
    github: "GitHub",
    youtube: "YouTube",
    boosty: "Boosty",
    patreon: "Patreon",
  },
  en: {
    telegram: "Telegram",
    github: "GitHub",
    youtube: "YouTube",
    boosty: "Boosty",
    patreon: "Patreon",
  },
};

const t = labels[lang];
---

<footer class="site-footer">
  <div class="inner">
    <p class="logo">&lt;(.____.)&gt;</p>

    <div class="socials" aria-label="Social links placeholders">
      <span class="social-item" title={t.telegram}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M21.7 3.4 2.9 10.7c-1.3.5-1.3 1.2-.2 1.6l4.8 1.5 1.8 5.6c.2.6.4.8.8.8.4 0 .6-.2.9-.5l2.6-2.5 5.3 3.9c1 .6 1.7.3 1.9-.9l3.4-15.8c.4-1.5-.5-2.2-1.7-1.7Zm-4.1 4.2-8.8 8-.3 3.1-1.3-4.3 10.4-6.8Z" />
        </svg>
        <span>{t.telegram}</span>
      </span>

      <span class="social-item" title={t.github}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5A3.9 3.9 0 0 1 6.6 7.8a3.6 3.6 0 0 1 .1-2.7s.9-.3 2.8 1.1a9.5 9.5 0 0 1 5 0c1.9-1.4 2.8-1.1 2.8-1.1.6 1.4.2 2.4.1 2.7a3.9 3.9 0 0 1 1.1 2.8c0 3.9-2.4 4.7-4.7 5 .4.3.7 1 .7 2v3.1c0 .3.2.6.7.5A10 10 0 0 0 12 2Z" />
        </svg>
        <span>{t.github}</span>
      </span>

      <span class="social-item" title={t.youtube}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 12s0-3.3-.4-4.9c-.2-.9-.9-1.6-1.8-1.8C18.2 5 12 5 12 5s-6.2 0-7.8.4c-.9.2-1.6.9-1.8 1.8C2 8.7 2 12 2 12s0 3.3.4 4.9c.2.9.9 1.6 1.8 1.8 1.6.4 7.8.4 7.8.4s6.2 0 7.8-.4c.9-.2 1.6-.9 1.8-1.8.4-1.6.4-4.9.4-4.9Zm-12 3.1V8.9l5.4 3.1-5.4 3.1Z" />
        </svg>
        <span>{t.youtube}</span>
      </span>

      <span class="social-item text-icon" title={t.boosty}>
        <span class="letter">B</span>
        <span>{t.boosty}</span>
      </span>

      <span class="social-item text-icon" title={t.patreon}>
        <span class="letter">P</span>
        <span>{t.patreon}</span>
      </span>
    </div>

    <p class="muted">© 2026</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 var(--space-md) 0;
    flex-shrink: 0;
  }

  .inner {
    width: min(100% - 2rem, var(--max-width));
    margin-inline: auto;
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius) var(--radius) 0 0;
    background: var(--color-footer);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-md);
  }

  .logo {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 700;
    white-space: nowrap;
  }

  .muted {
    margin: 0;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .socials {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .social-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.32rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-footer) 78%, white);
    color: var(--color-muted);
    font-size: 0.82rem;
    line-height: 1;
    user-select: none;
  }

  .social-item svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .letter {
    width: 1rem;
    height: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 800;
    font-family: var(--font-mono);
    line-height: 1;
  }

  @media (max-width: 760px) {
    .inner {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .socials {
      justify-content: flex-start;
    }
  }
</style>