---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ProjectDescriptionCard from "../../components/projects/ProjectDescriptionCard.astro";
import { getProjects } from "../../lib/projects/catalog";

const logo = "<(.____.)>";
const projects = getProjects();
---

<BaseLayout
  title={`Проекты — ${logo}`}
  description="Описание текущих и запланированных проектов."
  lang="ru"
>
  <PageHeader
    title="Проекты"
    description="Краткое описание текущих и запланированных направлений."
  />

  <section class="grid">
    {projects.map((project) => <ProjectDescriptionCard project={project} lang="ru" />)}
  </section>

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
