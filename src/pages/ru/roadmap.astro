---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`План — ${logo}`}
  description="Публичная дорожная карта сайта и связанных проектов."
  lang="ru"
>
  <PageHeader
    title="План"
    description="Публичная дорожная карта сайта, контента, проектов и будущих улучшений."
  />

  <section>
    <h2>Лето 2026</h2>

    <ul>
      <li>собрать первую версию сайта;</li>
      <li>настроить двуязычную структуру;</li>
      <li>сделать основные разделы;</li>
      <li>добавить первые материалы;</li>
      <li>опубликовать сайт на домене.</li>
    </ul>
  </section>

  <section>
    <h2>Версия 0.1</h2>

    <ul>
      <li>главная страница;</li>
      <li>страницы Math, Programming, Game, Blog, Projects, Shop;</li>
      <li>русский и английский языки;</li>
      <li>базовый дизайн;</li>
      <li>первые заметки.</li>
    </ul>
  </section>

  <section>
    <h2>Версия 0.2</h2>

    <ul>
      <li>MDX-статьи;</li>
      <li>теги;</li>
      <li>списки материалов по разделам;</li>
      <li>RSS;</li>
      <li>улучшенное SEO;</li>
      <li>больше devlog-материалов.</li>
    </ul>
  </section>

  <section>
    <h2>Версия 1.0</h2>

    <ul>
      <li>устойчивый контентный процесс;</li>
      <li>полноценное портфолио;</li>
      <li>удобная навигация;</li>
      <li>хорошая мобильная версия;</li>
      <li>публичная база знаний.</li>
    </ul>
  </section>

  <section>
    <h2>Будущее</h2>

    <ul>
      <li>поиск по сайту;</li>
      <li>страницы проектов с подробными описаниями;</li>
      <li>интеграция с медиа-платформами;</li>
      <li>витрина мерча;</li>
      <li>возможная торговая секция.</li>
    </ul>
  </section>
</BaseLayout>