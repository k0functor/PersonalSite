---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import IumSectionCard from "../../../components/ium/IumSectionCard.astro";
import { getSectionSheetCount, getSortedIumSections } from "../../../lib/ium/catalog";

const logo = "<(.____.)>";
const sections = getSortedIumSections();
---

<BaseLayout
  title={`НМУ — ${logo}`}
  description="Разделы НМУ, листочки и решения в PDF."
  lang="ru"
>
  <PageHeader
    title="НМУ"
    description="Разделы, листочки, условия и решения в формате PDF."
  />

  <section class="intro">
    <p>
      Здесь хранятся листочки НМУ и мои решения. Условия и решения доступны в
      PDF: можно открыть предпросмотр прямо на сайте или скачать файл.
    </p>
  </section>

  <section class="grid">
    {sections.map((section) => (
      <IumSectionCard section={section} count={getSectionSheetCount(section.id)} />
    ))}
  </section>

  <style>
    .intro {
      margin-bottom: var(--space-xl);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
