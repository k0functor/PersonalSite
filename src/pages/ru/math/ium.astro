---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import IumSheetCard from "../../../components/IumSheetCard.astro";

const logo = "<(.____.)>";

const sheets = await getCollection("math-ium", ({ data }) => data.lang === "ru");

const sortedSheets = sheets.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title={`НМУ — ${logo}`}
  description="Листочки НМУ, решения и математические заметки в LaTeX."
  lang="ru"
>
  <PageHeader
    title="НМУ"
    description="Листочки, решения, статусы сдачи и заметки по задачам."
  />

  <section class="intro">
    <p>
      Здесь будут храниться листочки НМУ и мои решения. Решения пишутся в MDX с
      поддержкой LaTeX, поэтому можно нормально отображать формулы, доказательства
      и математические выкладки.
    </p>
  </section>

  <section class="grid">
    {sortedSheets.map((entry) => <IumSheetCard entry={entry} />)}
  </section>

  <style>
    .intro {
      margin-bottom: var(--space-xl);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>