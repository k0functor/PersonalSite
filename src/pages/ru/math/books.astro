---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import MathBookCard from "../../../components/math/MathBookCard.astro";
import books from "../../../data/math/books.json";

const logo = "<(.____.)>";
const sortedBooks = [...books].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
---

<BaseLayout
  title={`Книги по математике — ${logo}`}
  description="Книги, которые я прочитал, читаю или планирую прочитать."
  lang="ru"
>
  <PageHeader
    title="Книги"
    description="Книги, которые я прочитал, читаю или планирую прочитать."
  />

  {sortedBooks.length > 0 ? (
    <section class="grid">
      {sortedBooks.map((book) => <MathBookCard book={book} lang="ru" />)}
    </section>
  ) : (
    <p>Книги пока не добавлены.</p>
  )}

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
