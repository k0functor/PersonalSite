---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionCard from "../../components/SectionCard.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`Математика — ${logo}`}
  description="Заметки, задачи, конспекты и учебный путь в математике."
  lang="ru"
>
  <PageHeader
    title="Математика"
    description="Заметки, задачи, конспекты, НМУ, МФТИ и области математики, которые я хочу изучить глубже."
  />

  <section class="intro">
    <p>
      Математика для меня — не декоративное приложение к программированию, а
      отдельная долгосрочная цель. Я хочу выстроить сильную базу, научиться
      решать задачи, понимать структуры и постепенно выйти на уровень
      исследовательской работы.
    </p>

    <p>
      Здесь будут появляться конспекты, разобранные задачи, карты тем, списки
      источников и заметки о том, как я изучаю разные области математики.
    </p>
  </section>

  <section class="grid">
    <SectionCard
      title="Книги"
      description="Книги, которые я прочитал, читаю или планирую прочитать."
      href="/ru/math/books/"
    />

    <SectionCard
      title="НМУ"
      description="Листочки с задачами, решения в LaTeX и статусы сдачи."
      href="/ru/math/ium/"
    />

    <SectionCard
      title="Алгебраическая топология"
      description="Топологические пространства, гомотопии, фундаментальная группа, гомологии и дальнейшие темы."
      href="/ru/math/algebraic-topology/"
    />

    <SectionCard
      title="Комплексный анализ и геометрия"
      description="Комплексный анализ, римановы поверхности, геометрические идеи и связанные темы."
      href="/ru/math/complex-analysis/"
    />

    <SectionCard
      title="Задачи"
      description="Разборы задач, идеи решений, ошибки, полезные приёмы и наблюдения."
      href="/ru/math/problems/"
    />

    <SectionCard
      title="Карты тем"
      description="Планы изучения математических областей: что читать, в каком порядке и какие связи важны."
      href="/ru/math/roadmaps/"
    />
  </section>

  <section>
    <h2>Планируемые материалы</h2>

    <ul>
      <li>Моя математическая карта на 2026 год</li>
      <li>Как я хочу работать с листочками НМУ</li>
      <li>Что нужно знать перед алгебраической топологией</li>
      <li>Как вести математический конспект</li>
      <li>Задачи, которые я не решил с первого раза</li>
    </ul>
  </section>

  <style>
    .intro {
      margin-bottom: var(--space-xl);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>