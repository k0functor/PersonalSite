---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionCard from "../../components/SectionCard.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`Математика — ${logo}`}
  description="НМУ, книги и учебные материалы по математике."
  lang="ru"
>
  <PageHeader
    title="Математика"
    description="Три основных направления: НМУ, книги и учёба."
  />

  <section class="grid">
    <SectionCard
      title="НМУ"
      description="Разделы, листочки, PDF условий и PDF решений."
      href="/ru/math/ium/"
    />

    <SectionCard
      title="Книги"
      description="Книги, которые я прочитал, читаю или планирую прочитать."
      href="/ru/math/books/"
    />

    <SectionCard
      title="Учёба"
      description="Учебные разделы: теория, задачи и экзаменационные материалы в PDF."
      href="/ru/math/study/"
    />
  </section>

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
