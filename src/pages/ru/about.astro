---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Timeline from "../../components/Timeline.astro";
import { ruTimeline } from "../../data/timeline";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`Обо мне — ${logo}`}
  description="Короткая информация обо мне и хронология."
  lang="ru"
>
  <PageHeader
    title="Обо мне"
    description="Коротко: кто я, чем занимаюсь и куда двигаюсь."
  />

  <section class="about">
    <div class="photo">
      <img src="/images/profile.jpg" alt="Фотография" />
    </div>

    <div>
      <p>
        Я изучаю математику, программирование и разработку игр. Сейчас мой
        основной фокус — C++, Computer Science, математическое образование и
        собственный игровой проект.
      </p>

      <p>
        Этот сайт — место, где я собираю заметки, учебный путь, проекты и devlog
        разработки.
      </p>
    </div>
  </section>

  <section>
    <h2>Хронология</h2>
    <Timeline items={ruTimeline} />
  </section>

  <style>
    .about {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: var(--space-lg);
      align-items: start;
      margin-bottom: var(--space-xl);
    }

    .photo {
      aspect-ratio: 1;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--color-border);
      background: var(--color-card);
    }

    .photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    @media (max-width: 700px) {
      .about {
        grid-template-columns: 1fr;
      }

      .photo {
        max-width: 220px;
      }
    }
  </style>
</BaseLayout>