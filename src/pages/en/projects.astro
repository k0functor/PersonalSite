---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import ProjectDescriptionCard from "../../components/projects/ProjectDescriptionCard.astro";
import { getProjects } from "../../lib/projects/catalog";

const logo = "<(.____.)>";
const projects = getProjects();
---

<BaseLayout
  title={`Projects — ${logo}`}
  description="Descriptions of current and planned projects."
  lang="en"
>
  <PageHeader
    title="Projects"
    description="Short descriptions of current and planned directions."
  />

  <section class="grid">
    {projects.map((project) => <ProjectDescriptionCard project={project} lang="en" />)}
  </section>

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
