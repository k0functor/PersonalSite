---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionCard from "../../components/SectionCard.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`Math — ${logo}`}
  description="IUM, books, and study materials."
  lang="en"
>
  <PageHeader
    title="Math"
    description="Three main directions: IUM, books, and study materials."
  />

  <section class="grid">
    <SectionCard
      title="IUM"
      description="This section is available only in Russian."
      href="/en/math/ium/"
    />

    <SectionCard
      title="Books"
      description="Books I have read, am reading, or plan to read."
      href="/en/math/books/"
    />

    <SectionCard
      title="Study"
      description="Study sections with theory, problems, and exam PDF materials."
      href="/en/math/study/"
    />
  </section>

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
