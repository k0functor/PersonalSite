---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`IUM — ${logo}`}
  description="This page is available only in Russian."
  lang="en"
>
  <PageHeader
    title="IUM"
    description="This page is available only in Russian."
  />

  <section class="notice">
    <p>
      The IUM problem sheets and solutions are currently maintained only in the
      Russian version of the website.
    </p>

    <p>
      <a href="/ru/math/ium/">Open the Russian IUM section</a>
    </p>
  </section>

  <style>
    .notice {
      padding: var(--space-lg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: var(--color-card);
    }

    .notice p:last-child {
      margin-bottom: 0;
    }
  </style>
</BaseLayout>
