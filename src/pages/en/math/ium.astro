---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import IumSheetCard from "../../../components/IumSheetCard.astro";

const logo = "<(.____.)>";

const sheets = await getCollection("math-ium", ({ data }) => data.lang === "en");

const sortedSheets = sheets.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title={`IUM — ${logo}`}
  description="IUM problem sheets, solutions, and mathematical notes in LaTeX."
  lang="en"
>
  <PageHeader
    title="IUM"
    description="Problem sheets, solutions, submission statuses, and notes."
  />

  <section class="intro">
    <p>
      This section contains IUM problem sheets and my solutions. The solutions
      are written in MDX with LaTeX support, so formulas, proofs, and mathematical
      derivations can be displayed properly.
    </p>
  </section>

  <section class="grid">
    {sortedSheets.map((entry) => <IumSheetCard entry={entry} lang="en" />)}
  </section>

  <style>
    .intro {
      margin-bottom: var(--space-xl);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>