---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import MathBookCard from "../../../components/math/MathBookCard.astro";
import books from "../../../data/math/books.json";

const logo = "<(.____.)>";
const sortedBooks = [...books].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
---

<BaseLayout
  title={`Math Books — ${logo}`}
  description="Books I have read, am reading, or plan to read."
  lang="en"
>
  <PageHeader
    title="Books"
    description="Books I have read, am reading, or plan to read."
  />

  {sortedBooks.length > 0 ? (
    <section class="grid">
      {sortedBooks.map((book) => <MathBookCard book={book} lang="en" />)}
    </section>
  ) : (
    <p>No books have been added yet.</p>
  )}

  <style>
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
