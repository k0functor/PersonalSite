---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const logo = "<(.____.)>";
---

<BaseLayout
  title={`Roadmap — ${logo}`}
  description="A public roadmap for the website and related projects."
  lang="en"
>
  <PageHeader
    title="Roadmap"
    description="A public roadmap for the website, content, projects, and future improvements."
  />

  <section>
    <h2>Summer 2026</h2>

    <ul>
      <li>build the first version of the website;</li>
      <li>set up the bilingual structure;</li>
      <li>create the main sections;</li>
      <li>add the first materials;</li>
      <li>publish the website on a domain.</li>
    </ul>
  </section>

  <section>
    <h2>Version 0.1</h2>

    <ul>
      <li>homepage;</li>
      <li>Math, Programming, Game, Blog, Projects, and Shop pages;</li>
      <li>Russian and English versions;</li>
      <li>basic design;</li>
      <li>first notes.</li>
    </ul>
  </section>

  <section>
    <h2>Version 0.2</h2>

    <ul>
      <li>MDX articles;</li>
      <li>tags;</li>
      <li>section-based material lists;</li>
      <li>RSS;</li>
      <li>improved SEO;</li>
      <li>more devlog materials.</li>
    </ul>
  </section>

  <section>
    <h2>Version 1.0</h2>

    <ul>
      <li>stable content workflow;</li>
      <li>proper portfolio;</li>
      <li>comfortable navigation;</li>
      <li>good mobile version;</li>
      <li>public knowledge base.</li>
    </ul>
  </section>

  <section>
    <h2>Future</h2>

    <ul>
      <li>site search;</li>
      <li>detailed project pages;</li>
      <li>media platform integration;</li>
      <li>merch showcase;</li>
      <li>possible shop section.</li>
    </ul>
  </section>
</BaseLayout>