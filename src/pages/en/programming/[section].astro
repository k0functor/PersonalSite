---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import ProgrammingMaterialCard from "../../../components/programming/ProgrammingMaterialCard.astro";
import {
  getProgrammingMaterialsBySection,
  getProgrammingSectionById,
  getSectionDescription,
  getSectionTitle,
  getSortedProgrammingSections,
  groupMaterialsByTopic,
} from "../../../lib/programming/catalog";

export function getStaticPaths() {
  return getSortedProgrammingSections().map((section) => ({
    params: { section: section.id },
  }));
}

const sectionId = Astro.params.section;
const section = typeof sectionId === "string" ? getProgrammingSectionById(sectionId) : undefined;

if (!section) {
  return Astro.redirect("/en/programming/");
}

const materials = getProgrammingMaterialsBySection(section.id, "en");
const groups = groupMaterialsByTopic(materials);
const title = getSectionTitle(section, "en");
const description = getSectionDescription(section, "en");
const logo = "<(.____.)>";
---

<BaseLayout title={`${title} — Programming — ${logo}`} description={description} lang="en">
  <p><a href="/en/programming/">← Programming</a></p>

  <PageHeader title={title} description={description} />

  {groups.length > 0 ? (
    <section class="topics">
      {groups.map((group) => (
        <section class="topic">
          <h2>{group.topic}</h2>
          <div class="grid">
            {group.items.map((material) => <ProgrammingMaterialCard material={material} lang="en" />)}
          </div>
        </section>
      ))}
    </section>
  ) : (
    <p>No materials yet.</p>
  )}

  <style>
    .topic + .topic {
      margin-top: var(--space-xl);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
  </style>
</BaseLayout>
