---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import sections from "../../../data/ium/sections.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const today = new Date().toISOString().slice(0, 10);
const availableSections = sections.filter((section) => section.lang === "ru");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить PDF-листочек НМУ — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="page">
      <p><a href="/admin/">← Админка</a></p>

      <header>
        <h1>Добавить PDF-листочек НМУ</h1>
        <p class="muted">
          Загрузит PDF условия, опционально PDF решения, добавит запись в
          <code>src/data/ium/sheets.json</code> и сделает commit в GitHub.
        </p>
      </header>

      {error && <p class="error">{error}</p>}

      {availableSections.length === 0 ? (
        <section class="card">
          <h2>Нет разделов</h2>
          <p>
            Сначала добавь хотя бы один раздел в
            <code>src/data/ium/sections.json</code>. Создание разделов через
            админку сейчас специально отключено.
          </p>
        </section>
      ) : (
        <form class="form" method="post" action="/api/admin/ium/create-pdf-sheet" enctype="multipart/form-data">
          <label>
            Раздел
            <select name="sectionId" required>
              {availableSections.map((section) => (
                <option value={section.id}>{section.title}</option>
              ))}
            </select>
          </label>

          <label>
            Slug листочка
            <input
              name="sheetId"
              placeholder="sheet-01"
              pattern="[a-z0-9-]+"
              required
            />
            <span class="hint">Только латиница, цифры и дефисы. Например: sheet-01.</span>
          </label>

          <label>
            Название
            <input name="title" placeholder="Листок 1" required />
          </label>

          <label>
            Описание
            <textarea name="description" rows="3" placeholder="Первые задачи по теме." required></textarea>
          </label>

          <label>
            Темы
            <input name="topics" placeholder="пределы, непрерывность, компактность" />
            <span class="hint">Через запятую.</span>
          </label>

          <label>
            Статус
            <select name="status" required>
              <option value="not-started">не начат</option>
              <option value="in-progress" selected>в процессе</option>
              <option value="partly-solved">решён частично</option>
              <option value="solved">решён</option>
              <option value="submitted">сдан</option>
              <option value="needs-rewrite">нужно переписать</option>
            </select>
          </label>

          <label>
            Дата
            <input name="date" type="date" value={today} required />
          </label>

          <label>
            PDF условия
            <input name="sheetPdf" type="file" accept="application/pdf,.pdf" required />
          </label>

          <label>
            PDF решения
            <input name="solutionPdf" type="file" accept="application/pdf,.pdf" />
            <span class="hint">Можно оставить пустым и добавить позже отдельным шагом.</span>
          </label>

          <button type="submit">Добавить листочек</button>
        </form>
      )}
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
  }

  .page {
    width: min(100% - 2rem, 760px);
    margin-inline: auto;
    padding: 2rem 0;
  }

  a {
    color: inherit;
    text-underline-offset: 0.2em;
  }

  h1 {
    margin-bottom: 0.25rem;
  }

  .muted,
  .hint {
    color: #6f6a5f;
  }

  .hint {
    font-size: 0.9rem;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
  }

  .error {
    padding: 0.75rem;
    border: 1px solid #b00020;
    border-radius: 8px;
    background: #fff0f2;
    color: #b00020;
  }

  .card,
  .form {
    margin-top: 1.5rem;
    padding: 1.25rem;
    border: 1px solid #cfc3b0;
    border-radius: 16px;
    background: #fffaf0;
  }

  .form {
    display: grid;
    gap: 1rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 700;
  }

  input,
  select,
  textarea {
    padding: 0.65rem;
    border: 1px solid #cfc3b0;
    border-radius: 6px;
    background: white;
    color: inherit;
    font: inherit;
  }

  textarea {
    resize: vertical;
  }

  button {
    justify-self: start;
    padding: 0.7rem 1rem;
    border: 1px solid #cfc3b0;
    border-radius: 6px;
    background: #ebe1d0;
    color: inherit;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  button:hover {
    background: #f3eadb;
  }
</style>
