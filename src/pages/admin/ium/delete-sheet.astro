---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import sections from "../../../data/ium/sections.json";
import sheets from "../../../data/ium/sheets.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const sectionById = new Map(sections.map((section) => [section.id, section]));

const grouped = sections
  .slice()
  .sort((a, b) => a.order - b.order)
  .map((section) => ({
    section,
    sheets: sheets
      .filter((sheet) => sheet.sectionId === section.id)
      .sort((a, b) => a.id.localeCompare(b.id, "ru", { numeric: true })),
  }));
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Удалить листочки НМУ — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="admin-shell">
      <p><a href="/admin/ium/">← НМУ</a></p>

      <header>
        <p class="logo">&lt;(.____.)&gt;</p>
        <h1>Удалить листочки НМУ</h1>
        <p class="muted">
          Удаление убирает листочек из каталога. По умолчанию вместе с ним удаляются PDF условия и решения из репозитория.
        </p>
      </header>

      {grouped.map(({ section, sheets }) => (
        <section class="section-block">
          <h2>{section.title}</h2>
          <p class="muted">{section.description}</p>

          {sheets.length > 0 ? (
            <div class="list">
              {sheets.map((sheet) => (
                <article class="card">
                  <div>
                    <h3>{sheet.title}</h3>
                    <p>{sheet.description}</p>
                    <p class="meta">
                      <span>ID: {sheet.id}</span>
                      <span>{sectionById.get(sheet.sectionId)?.title ?? sheet.sectionId}</span>
                      <span>{sheet.status}</span>
                    </p>
                    <p class="links">
                      {sheet.sheetPdf && <a href={sheet.sheetPdf} target="_blank">условие</a>}
                      {sheet.solutionPdf && <a href={sheet.solutionPdf} target="_blank">решение</a>}
                      <a href={`/ru/math/ium/${section.id}/${sheet.id}/`} target="_blank">на сайте</a>
                    </p>
                  </div>

                  <form
                    method="post"
                    action="/api/admin/ium/delete-sheet"
                    onsubmit={`return confirm('Удалить листочек ${sheet.title}? Это действие сделает commit в GitHub.');`}
                  >
                    <input type="hidden" name="sectionId" value={section.id} />
                    <input type="hidden" name="sheetId" value={sheet.id} />

                    <label class="checkbox">
                      <input type="checkbox" name="deletePdfFiles" value="yes" checked />
                      удалить PDF-файлы
                    </label>

                    <button type="submit">Удалить</button>
                  </form>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty">В этом разделе нет листочков.</p>
          )}
        </section>
      ))}
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
  }

  body {
    margin: 0;
  }

  .admin-shell {
    width: min(100% - 2rem, 960px);
    margin: 0 auto;
    padding: 2rem 0;
  }

  .logo {
    font-family: monospace;
    font-weight: 700;
  }

  a {
    color: inherit;
  }

  .muted,
  .empty,
  .meta {
    color: #6f6a5f;
  }

  .section-block {
    margin-top: 2.5rem;
  }

  .list {
    display: grid;
    gap: 1rem;
  }

  .card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #cfc3b0;
    border-radius: 12px;
    background: #fffaf0;
  }

  h3 {
    margin: 0;
  }

  .meta,
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  form {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    justify-items: end;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #6f6a5f;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  button {
    padding: 0.55rem 0.85rem;
    border: 1px solid #8f3f3f;
    border-radius: 4px;
    background: #fff0f0;
    color: #7a1f1f;
    cursor: pointer;
    font: inherit;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease;
  }

  button:hover {
    transform: translateY(2px);
    background: #ffe1e1;
    border-color: #7a1f1f;
  }

  @media (max-width: 760px) {
    .card {
      grid-template-columns: 1fr;
    }

    form {
      justify-items: start;
    }
  }
</style>
