---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import sections from "../../../data/ium/sections.json";
import sheets from "../../../data/ium/sheets.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const sortedSections = [...sections].sort((a, b) => a.order - b.order);
const sortedSheets = [...sheets].sort((a, b) =>
  a.sectionId.localeCompare(b.sectionId, "ru") || a.id.localeCompare(b.id, "ru", { numeric: true })
);

function countSheets(sectionId: string) {
  return sheets.filter((sheet) => sheet.sectionId === sectionId).length;
}

function sectionTitle(sectionId: string) {
  return sections.find((section) => section.id === sectionId)?.title ?? sectionId;
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>НМУ — админка</title>
  </head>

  <body>
    <main class="page">
      <p><a href="/admin/math/">← Математика</a></p>

      <header class="header">
        <p class="logo">&lt;(.____.)&gt;</p>
        <h1>НМУ</h1>
        <p>Управление разделами, PDF-листочками и решениями.</p>
      </header>

      <section class="actions">
        <a href="/admin/ium/new-section/">Добавить раздел</a>
        <a href="/admin/ium/delete-section/">Удалить раздел</a>
        <a href="/admin/ium/new-sheet/">Добавить PDF-листочек</a>
        <a href="/admin/ium/edit-sheet/">Редактировать листочек</a>
        <a href="/admin/ium/delete-sheet/">Удалить листочек</a>
      </section>

      <section>
        <h2>Разделы</h2>

        {sortedSections.length > 0 ? (
          <div class="list">
            {sortedSections.map((section) => (
              <article class="card section-card">
                <div>
                  <h3>{section.title}</h3>
                  <p>{section.description}</p>
                </div>

                <dl>
                  <div>
                    <dt>ID</dt>
                    <dd>{section.id}</dd>
                  </div>
                  <div>
                    <dt>Порядок</dt>
                    <dd>{section.order}</dd>
                  </div>
                  <div>
                    <dt>Листочков</dt>
                    <dd>{countSheets(section.id)}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        ) : (
          <p>Разделов пока нет.</p>
        )}
      </section>

      <section>
        <h2>Листочки</h2>

        {sortedSheets.length > 0 ? (
          <div class="list">
            {sortedSheets.map((sheet) => (
              <article class="card sheet-card">
                <div>
                  <h3>{sheet.title}</h3>
                  <p>{sheet.description}</p>
                  <p class="muted">{sectionTitle(sheet.sectionId)} / {sheet.id} / {sheet.status}</p>
                </div>

                <div class="sheet-actions">
                  <a href={`/ru/math/ium/${sheet.sectionId}/${sheet.id}/`} target="_blank">Открыть</a>
                  <a href={`/admin/ium/edit-sheet/${sheet.sectionId}/${sheet.id}/`}>Редактировать</a>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p>Листочков пока нет.</p>
        )}
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #181612;
    background: #f7f4ed;
  }

  body {
    margin: 0;
  }

  .page {
    width: min(100% - 2rem, 960px);
    margin: 0 auto;
    padding: 2rem 0;
  }

  .logo {
    font-family: monospace;
    font-weight: 700;
  }

  .header {
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .actions a,
  a {
    color: inherit;
  }

  .actions a,
  .sheet-actions a {
    display: inline-flex;
    padding: 0.55rem 0.85rem;
    border: 1px solid #cfc3b0;
    border-radius: 4px;
    background: #fffaf0;
    text-decoration: none;
  }

  .actions a:hover,
  .sheet-actions a:hover {
    background: #f3eadb;
  }

  section + section {
    margin-top: 2.5rem;
  }

  .list {
    display: grid;
    gap: 1rem;
  }

  .card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #cfc3b0;
    border-radius: 12px;
    background: #fffaf0;
  }

  h3 {
    margin: 0;
  }

  .muted,
  p {
    color: #6f6a5f;
  }

  dl {
    display: grid;
    gap: 0.35rem;
    min-width: 180px;
    margin: 0;
  }

  dl div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  dt {
    color: #6f6a5f;
  }

  dd {
    margin: 0;
    font-weight: 600;
  }

  .sheet-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-content: start;
    gap: 0.5rem;
  }

  @media (max-width: 720px) {
    .card {
      grid-template-columns: 1fr;
    }

    .sheet-actions {
      justify-content: flex-start;
    }
  }
</style>
