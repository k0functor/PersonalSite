---
export const prerender = false;

import { requireAdmin } from "../../../lib/admin/auth";

const redirect = await requireAdmin(Astro.cookies);
if (redirect) return redirect;

const error = Astro.url.searchParams.get("error");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить раздел НМУ — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main>
      <p><a href="/admin/ium/">← НМУ Admin</a></p>

      <h1>Добавить раздел НМУ</h1>

      {error && <p class="error">Ошибка: {error}</p>}

      <form method="post" action="/api/admin/ium/create-section">
        <label>
          Название
          <input name="title" required placeholder="Матанализ 1" />
        </label>

        <label>
          Slug / id
          <input name="id" placeholder="calculus-1" />
          <small>Если оставить пустым, будет сгенерирован из названия. Лучше писать латиницей.</small>
        </label>

        <label>
          Описание
          <textarea name="description" required rows="4" placeholder="Листочки и решения по математическому анализу 1."></textarea>
        </label>

        <label>
          Порядок сортировки
          <input name="order" type="number" value="100" />
        </label>

        <button type="submit">Добавить раздел</button>
      </form>
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      main { width: min(100% - 2rem, 760px); margin: 3rem auto; }
      form { display: grid; gap: 1rem; }
      label { display: grid; gap: 0.35rem; }
      input, textarea, button { font: inherit; }
      input, textarea { padding: 0.7rem; border: 1px solid #cfc3b0; border-radius: 8px; background: #fffaf0; }
      button { width: fit-content; padding: 0.7rem 1rem; border: 1px solid #cfc3b0; border-radius: 4px; background: #ebe1d0; cursor: pointer; }
      small, .error { color: #6f6a5f; }
      .error { padding: 0.75rem; border: 1px solid #8a3a1b; border-radius: 8px; color: #8a3a1b; background: #fff4ea; }
    </style>
  </body>
</html>
