---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import sections from "../../../data/ium/sections.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
const nextOrder = sections.length > 0 ? Math.max(...sections.map((section) => section.order)) + 1 : 1;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить раздел НМУ</title>
  </head>

  <body>
    <main class="page">
      <p><a href="/admin/ium/">← НМУ</a></p>

      <h1>Добавить раздел НМУ</h1>
      <p>Создай новый раздел вроде “Матанализ 1”, “Алгебра 1”, “Топология 2”.</p>

      {success === "created" && <p class="success">Раздел добавлен. Сделай git pull локально, если проверяешь сайт на компьютере.</p>}
      {error === "invalid" && <p class="error">Проверь поля формы. ID должен содержать только латинские буквы, цифры и дефисы.</p>}
      {error === "exists" && <p class="error">Раздел с таким ID уже существует.</p>}
      {error === "server" && <p class="error">Ошибка сервера. Смотри терминал npm run dev.</p>}

      <form method="post" action="/api/admin/ium/create-section" class="form">
        <label>
          Название раздела
          <input name="title" required placeholder="Матанализ 1" />
        </label>

        <label>
          ID / slug раздела
          <input name="id" required placeholder="calculus-1" pattern="[a-z0-9-]+" />
          <small>Только латинские буквы, цифры и дефисы. Например: calculus-1, algebra-1, topology-2.</small>
        </label>

        <label>
          Описание
          <textarea name="description" rows="4" required placeholder="Листочки и решения по математическому анализу 1."></textarea>
        </label>

        <label>
          Порядок сортировки
          <input name="order" type="number" value={nextOrder} required />
        </label>

        <input type="hidden" name="lang" value="ru" />

        <button type="submit">Добавить раздел</button>
      </form>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #181612;
    background: #f7f4ed;
  }

  body {
    margin: 0;
  }

  .page {
    width: min(100% - 2rem, 760px);
    margin: 0 auto;
    padding: 2rem 0;
  }

  .form {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
  }

  input,
  textarea,
  button {
    font: inherit;
  }

  input,
  textarea {
    padding: 0.6rem 0.7rem;
    border: 1px solid #cfc3b0;
    border-radius: 4px;
    background: #fffaf0;
  }

  small {
    color: #6f6a5f;
    font-weight: 400;
  }

  button {
    width: fit-content;
    padding: 0.6rem 0.9rem;
    border: 1px solid #cfc3b0;
    border-radius: 4px;
    background: #ebe1d0;
    cursor: pointer;
  }

  button:hover {
    background: #f3eadb;
  }

  .error,
  .success {
    padding: 0.75rem;
    border-radius: 8px;
  }

  .error {
    border: 1px solid #b00020;
    color: #b00020;
    background: #fff0f2;
  }

  .success {
    border: 1px solid #2f5d50;
    color: #2f5d50;
    background: #eef7f3;
  }
</style>
