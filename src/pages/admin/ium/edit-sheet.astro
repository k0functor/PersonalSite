---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import sections from "../../../data/ium/sections.json";
import sheets from "../../../data/ium/sheets.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const sectionById = new Map(sections.map((section) => [section.id, section]));

const grouped = sections
  .slice()
  .sort((a, b) => a.order - b.order)
  .map((section) => ({
    section,
    sheets: sheets
      .filter((sheet) => sheet.sectionId === section.id)
      .sort((a, b) => a.id.localeCompare(b.id)),
  }));
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Редактировать листочки — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="admin-shell">
      <p><a href="/admin/">← Админка</a></p>

      <header>
        <p class="logo">&lt;(.____.)&gt;</p>
        <h1>Редактировать листочки НМУ</h1>
        <p class="muted">
          Выбери листочек. Можно изменить метаданные, статус, темы и при
          необходимости заменить PDF условия или решения.
        </p>
      </header>

      {grouped.map(({ section, sheets }) => (
        <section class="section-block">
          <h2>{section.title}</h2>
          <p class="muted">{section.description}</p>

          {sheets.length > 0 ? (
            <div class="grid">
              {sheets.map((sheet) => (
                <a class="card" href={`/admin/ium/edit-sheet/${section.id}/${sheet.id}/`}>
                  <h3>{sheet.title}</h3>
                  <p>{sheet.description}</p>
                  <p class="meta">
                    <span>{sectionById.get(sheet.sectionId)?.title ?? sheet.sectionId}</span>
                    <span>{sheet.status}</span>
                  </p>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty">В этом разделе пока нет листочков.</p>
          )}
        </section>
      ))}
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
  }

  body {
    margin: 0;
  }

  .admin-shell {
    width: min(100% - 2rem, 960px);
    margin: 0 auto;
    padding: 2rem 0;
  }

  .logo {
    font-family: monospace;
    font-weight: 700;
  }

  a {
    color: inherit;
  }

  .muted,
  .empty {
    color: #6f6a5f;
  }

  .section-block {
    margin-top: 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1.25rem;
    border: 1px solid #cfc3b0;
    border-radius: 14px;
    background: #fffaf0;
    color: inherit;
    text-decoration: none;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease;
  }

  .card:hover {
    transform: translateY(2px);
    background: #f3eadb;
    border-color: #2f5d50;
  }

  .card h3 {
    margin-top: 0;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #6f6a5f;
    font-size: 0.9rem;
  }
</style>
