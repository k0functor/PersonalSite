---
export const prerender = false;

import { requireAdmin } from "../../../lib/admin/auth";
import { getSectionById, iumSheets } from "../../../lib/ium/catalog";

const redirect = await requireAdmin(Astro.cookies);
if (redirect) return redirect;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Редактировать листочек НМУ — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main>
      <p><a href="/admin/ium/">← НМУ Admin</a></p>

      <h1>Редактировать листочек</h1>

      <section class="list">
        {iumSheets.map((sheet) => {
          const section = getSectionById(sheet.sectionId);
          return (
            <a href={`/admin/ium/edit-sheet/${sheet.sectionId}/${sheet.id}/`}>
              <strong>{section?.title ?? sheet.sectionId} / {sheet.title}</strong>
              <span>{sheet.description}</span>
            </a>
          );
        })}
      </section>
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      main { width: min(100% - 2rem, 900px); margin: 3rem auto; }
      .list { display: grid; gap: 0.75rem; }
      .list a { display: grid; gap: 0.25rem; padding: 1rem; border: 1px solid #cfc3b0; border-radius: 10px; background: #fffaf0; color: inherit; text-decoration: none; }
      span { color: #6f6a5f; }
    </style>
  </body>
</html>
