---
export const prerender = false;

const error = Astro.url.searchParams.get("error");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Вход в админку — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="page">
      <section class="card">
        <h1>Вход в админку</h1>
        <p class="muted">Закрытая панель управления PDF-листочками НМУ.</p>

        {error === "invalid-password" && (
          <p class="error">Неверный пароль. Проверь ADMIN_PASSWORD в .env.</p>
        )}

        {error === "server-error" && (
          <p class="error">Ошибка сервера. Проверь терминал, где запущен npm run dev.</p>
        )}

        <form method="post" action="/api/admin/login">
          <label>
            Пароль
            <input name="password" type="password" autocomplete="current-password" required />
          </label>

          <button type="submit">Войти</button>
        </form>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
    display: grid;
    place-items: center;
  }

  .page {
    width: min(100% - 2rem, 440px);
  }

  .card {
    padding: 1.5rem;
    border: 1px solid #cfc3b0;
    border-radius: 16px;
    background: #fffaf0;
  }

  h1 {
    margin-top: 0;
  }

  .muted {
    color: #6f6a5f;
  }

  .error {
    padding: 0.75rem;
    border: 1px solid #b00020;
    border-radius: 8px;
    background: #fff0f2;
    color: #b00020;
  }

  form {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
    font-weight: 600;
  }

  input {
    padding: 0.65rem;
    border: 1px solid #cfc3b0;
    border-radius: 6px;
    font: inherit;
  }

  button {
    padding: 0.65rem 0.9rem;
    border: 1px solid #cfc3b0;
    border-radius: 6px;
    background: #ebe1d0;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  button:hover {
    background: #f3eadb;
  }
</style>
