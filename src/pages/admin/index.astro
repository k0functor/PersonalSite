---
export const prerender = false;

import { isAdminRequest } from "../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Админка — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="admin-shell">
      <header>
        <p class="logo">&lt;(.____.)&gt;</p>
        <h1>Админка</h1>
        <p class="muted">
          Сейчас админка работает только с PDF-листочками НМУ. Остальное не
          трогаем, чтобы не превратить интерфейс в панель управления атомной
          станцией.
        </p>
      </header>

      <section class="grid">
        <a class="card" href="/admin/ium/new-sheet/">
          <h2>Добавить PDF-листочек</h2>
          <p>Создать новый листочек НМУ, загрузить PDF условия и PDF решения.</p>
        </a>

        <a class="card" href="/admin/ium/edit-sheet/">
          <h2>Редактировать листочки</h2>
          <p>Изменить метаданные, статус, темы или заменить PDF-файлы.</p>
        </a>
      </section>

      <form method="post" action="/api/admin/logout" class="logout-form">
        <button type="submit">Выйти</button>
      </form>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
  }

  body {
    margin: 0;
  }

  .admin-shell {
    width: min(100% - 2rem, 960px);
    margin: 0 auto;
    padding: 2rem 0;
  }

  .logo {
    font-family: monospace;
    font-weight: 700;
  }

  .muted {
    color: #6f6a5f;
    max-width: 70ch;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    display: block;
    padding: 1.25rem;
    border: 1px solid #cfc3b0;
    border-radius: 14px;
    background: #fffaf0;
    color: inherit;
    text-decoration: none;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease;
  }

  .card:hover {
    transform: translateY(2px);
    background: #f3eadb;
    border-color: #2f5d50;
  }

  .card h2 {
    margin-top: 0;
  }

  .logout-form {
    margin-top: 2rem;
  }

  button {
    padding: 0.55rem 0.85rem;
    border: 1px solid #cfc3b0;
    border-radius: 4px;
    background: #fffaf0;
    cursor: pointer;
  }
</style>
