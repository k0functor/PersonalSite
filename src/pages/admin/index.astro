---
export const prerender = false;

import { isAdminRequest } from "../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Админка — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="admin">
      <h1>Админка</h1>
      <p>Центральная панель управления разделами сайта.</p>

      <section class="grid">
        <a class="card active" href="/admin/math/">
          <h2>Математика</h2>
          <p>НМУ, книги, учёба, PDF-материалы.</p>
        </a>

        <a class="card active" href="/admin/programming/">
          <h2>Программирование</h2>
          <p>C++, Python, алгоритмы, структуры данных, кодовые материалы и задачи.</p>
        </a>

        <article class="card muted">
          <h2>Игра</h2>
          <p>Будущий модуль для devlog, персонажей, карт и баланса.</p>
        </article>

        <article class="card muted">
          <h2>Блог</h2>
          <p>Будущий модуль для общих статей.</p>
        </article>

        <article class="card muted">
          <h2>Проекты</h2>
          <p>Будущий модуль для управления проектами.</p>
        </article>
      </section>

      <form method="post" action="/api/admin/logout">
        <button type="submit">Выйти</button>
      </form>
    </main>

    <style>
      body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 960px); margin: 2rem auto; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; margin: 2rem 0; }
      .card { display: block; padding: 1rem; border: 1px solid #cfc3b0; border-radius: 12px; background: #fffaf0; color: inherit; text-decoration: none; }
      .card.active:hover { border-color: #2f5d50; background: #f3eadb; }
      .card.muted { opacity: 0.65; }
      .card h2 { margin-top: 0; font-size: 1.15rem; }
      .card p { margin-bottom: 0; color: #6f6a5f; }
      button { padding: 0.5rem 0.85rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; cursor: pointer; }
      button:hover { background: #f3eadb; }
    </style>
  </body>
</html>
