---
export const prerender = false;

import { isAdminRequest } from "../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Админка — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="page">
      <header class="header">
        <div>
          <p class="logo">&lt;(.____.)&gt;</p>
          <h1>Админка</h1>
          <p class="muted">Пока здесь есть только добавление PDF-листочков НМУ.</p>
        </div>

        <form method="post" action="/api/admin/logout">
          <button type="submit">Выйти</button>
        </form>
      </header>

      <section class="grid">
        <a class="card" href="/admin/ium/new-sheet/">
          <h2>Добавить PDF-листочек НМУ</h2>
          <p>Условие, решение, раздел, темы, статус и метаданные.</p>
        </a>
      </section>

      <p class="muted small">
        Остальной функционал админки временно отключён. Сайт взрослеет не сразу,
        как и все проекты, которые не хочется потом сжечь.
      </p>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
  }

  .page {
    width: min(100% - 2rem, 900px);
    margin-inline: auto;
    padding: 2rem 0;
  }

  .header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .logo {
    margin: 0;
    font-family: monospace;
    font-weight: 700;
  }

  h1 {
    margin: 0.25rem 0;
  }

  .muted {
    color: #6f6a5f;
  }

  .small {
    margin-top: 1.5rem;
    font-size: 0.95rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1.25rem;
    border: 1px solid #cfc3b0;
    border-radius: 14px;
    background: #fffaf0;
    color: inherit;
    text-decoration: none;
  }

  .card:hover {
    border-color: #2f5d50;
    background: #f3eadb;
  }

  button {
    padding: 0.55rem 0.8rem;
    border: 1px solid #cfc3b0;
    border-radius: 6px;
    background: #ebe1d0;
    font: inherit;
    cursor: pointer;
  }
</style>
