---
export const prerender = false;

import { isAdminRequest } from "../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Админка — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="admin">
      <h1>Админка</h1>

      <p>
        Центральная панель управления сайтом. Сейчас активно настраиваем модуль математики.
      </p>

      <section class="grid">
        <a class="card active" href="/admin/math/">
          <h2>Математика</h2>
          <p>НМУ, книги и учебные материалы.</p>
        </a>

        <div class="card disabled">
          <h2>Программирование</h2>
          <p>Будущий модуль для C++, CS и алгоритмов.</p>
        </div>

        <div class="card disabled">
          <h2>Игра</h2>
          <p>Будущий модуль для devlog, персонажей, карт и баланса.</p>
        </div>

        <div class="card disabled">
          <h2>Блог</h2>
          <p>Будущий модуль для статей и заметок.</p>
        </div>
      </section>

      <form method="post" action="/api/admin/logout">
        <button type="submit">Выйти</button>
      </form>
    </main>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f4ed;
        color: #181612;
      }

      .admin {
        width: min(100% - 2rem, 960px);
        margin: 3rem auto;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        margin: 2rem 0;
      }

      .card {
        display: block;
        padding: 1rem;
        border: 1px solid #cfc3b0;
        border-radius: 12px;
        background: #fffaf0;
        color: inherit;
        text-decoration: none;
      }

      .active:hover {
        border-color: #2f5d50;
      }

      .disabled {
        opacity: 0.55;
      }

      .card h2 {
        margin-top: 0;
        font-size: 1.15rem;
      }

      .card p {
        margin-bottom: 0;
        color: #6f6a5f;
      }

      button {
        padding: 0.5rem 0.85rem;
        border: 1px solid #cfc3b0;
        border-radius: 6px;
        background: #ebe1d0;
        cursor: pointer;
      }
    </style>
  </body>
</html>
