---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import {
  getProgrammingMaterialsBySection,
  getSectionDescription,
  getSectionTitle,
  getSortedProgrammingSections,
} from "../../../lib/programming/catalog";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const sections = getSortedProgrammingSections();
const error = Astro.url.searchParams.get("error");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Программирование — админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/">← Админка</a></p>

      <h1>Программирование</h1>
      <p>Материалы сгруппированы по разделам. Открывай нужный раздел и работай с его страницами там.</p>

      {error && <p class="error">Ошибка: {error}</p>}

      <section class="grid">
        {sections.map((section) => {
          const ruCount = getProgrammingMaterialsBySection(section.id, "ru").length;
          const enCount = getProgrammingMaterialsBySection(section.id, "en").length;

          return (
            <a class="card" href={`/admin/programming/${section.id}/`}>
              <h2>{getSectionTitle(section, "ru")}</h2>
              <p>{getSectionDescription(section, "ru")}</p>
              <p class="meta">RU: {ruCount} · EN: {enCount}</p>
            </a>
          );
        })}
      </section>
    </main>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f4ed;
        color: #181612;
      }

      .admin {
        width: min(100% - 2rem, 1040px);
        margin: 2rem auto;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
      }

      .card {
        display: block;
        padding: 1rem;
        border: 1px solid #cfc3b0;
        border-radius: 12px;
        background: #fffaf0;
        color: inherit;
        text-decoration: none;
      }

      .card:hover {
        border-color: #2f5d50;
        background: #f3eadb;
      }

      .card h2 {
        margin-top: 0;
      }

      .card p {
        color: #6f6a5f;
      }

      .meta {
        margin-bottom: 0;
        font-weight: 700;
      }

      .error {
        padding: 0.75rem;
        border: 1px solid #b00020;
        border-radius: 8px;
        background: #fff0f2;
        color: #b00020;
      }
    </style>
  </body>
</html>
