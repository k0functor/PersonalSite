---
export const prerender = false;

import { isAdminRequest } from "../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const message = Astro.url.searchParams.get("message") || "Готово.";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Готово — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="page">
      <section class="card">
        <h1>Готово</h1>
        <p>{message}</p>
        <p><a href="/admin/">Вернуться в админку</a></p>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f7f4ed;
    color: #181612;
    display: grid;
    place-items: center;
  }

  .page {
    width: min(100% - 2rem, 520px);
  }

  .card {
    padding: 1.5rem;
    border: 1px solid #cfc3b0;
    border-radius: 16px;
    background: #fffaf0;
  }
</style>
