---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import { getProjects, getStatusLabel } from "../../../lib/projects/catalog";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
const projects = getProjects();
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Проекты — админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/">← Админка</a></p>

      <h1>Проекты</h1>
      <p>Добавление и удаление описаний проектов на публичной странице.</p>

      {error && <p class="error">Ошибка: {error}</p>}
      {success === "created" && <p class="success">Проект добавлен.</p>}
      {success === "deleted" && <p class="success">Проект удалён.</p>}

      <p>
        <a class="button" href="/admin/projects/new/">Добавить проект</a>
      </p>

      <section class="list">
        {projects.map((project) => (
          <article class="item">
            <div>
              <h2>{project.titleRu}</h2>
              <p>{project.descriptionRu}</p>
              <p class="meta">
                ID: <code>{project.id}</code> · Статус: {getStatusLabel(project.status, "ru")} · Порядок: {project.order}
              </p>
            </div>

            <form method="post" action="/api/admin/projects/delete-project">
              <input type="hidden" name="id" value={project.id} />
              <button type="submit" onclick="return confirm('Удалить проект?')">
                Удалить
              </button>
            </form>
          </article>
        ))}
      </section>
    </main>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f4ed;
        color: #181612;
      }

      .admin {
        width: min(100% - 2rem, 960px);
        margin: 2rem auto;
      }

      .button,
      button {
        display: inline-flex;
        padding: 0.5rem 0.85rem;
        border: 1px solid #cfc3b0;
        border-radius: 6px;
        background: #ebe1d0;
        color: inherit;
        text-decoration: none;
        cursor: pointer;
      }

      .list {
        display: grid;
        gap: 1rem;
        margin-top: 1.5rem;
      }

      .item {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid #cfc3b0;
        border-radius: 12px;
        background: #fffaf0;
      }

      h2 {
        margin-top: 0;
      }

      .meta {
        color: #6f6a5f;
      }

      .error {
        padding: 0.75rem;
        border: 1px solid #b00020;
        border-radius: 8px;
        color: #b00020;
        background: #fff0f2;
      }

      .success {
        padding: 0.75rem;
        border: 1px solid #2f5d50;
        border-radius: 8px;
        color: #2f5d50;
        background: #edf7f2;
      }

      @media (max-width: 700px) {
        .item {
          flex-direction: column;
        }
      }
    </style>
  </body>
</html>
