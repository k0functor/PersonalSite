---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить проект — админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/projects/">← Проекты</a></p>

      <h1>Добавить проект</h1>

      {error && <p class="error">Ошибка: {error}</p>}

      <form method="post" action="/api/admin/projects/create-project">
        <label>
          ID / slug
          <input name="id" required placeholder="math-notes" />
        </label>

        <label>
          Название RU
          <input name="titleRu" required />
        </label>

        <label>
          Название EN
          <input name="titleEn" required />
        </label>

        <label>
          Описание RU
          <textarea name="descriptionRu" required rows="4"></textarea>
        </label>

        <label>
          Описание EN
          <textarea name="descriptionEn" required rows="4"></textarea>
        </label>

        <label>
          Статус
          <select name="status" required>
            <option value="in-progress">in progress</option>
            <option value="planned">planned</option>
            <option value="done">done</option>
            <option value="paused">paused</option>
          </select>
        </label>

        <label>
          Порядок
          <input name="order" type="number" value="10" required />
        </label>

        <button type="submit">Добавить</button>
      </form>
    </main>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f4ed;
        color: #181612;
      }

      .admin {
        width: min(100% - 2rem, 760px);
        margin: 2rem auto;
      }

      form {
        display: grid;
        gap: 1rem;
      }

      label {
        display: grid;
        gap: 0.35rem;
      }

      input,
      textarea,
      select {
        padding: 0.55rem;
        border: 1px solid #cfc3b0;
        border-radius: 6px;
        background: #fffaf0;
        font: inherit;
      }

      button {
        width: fit-content;
        padding: 0.5rem 0.85rem;
        border: 1px solid #cfc3b0;
        border-radius: 6px;
        background: #ebe1d0;
        cursor: pointer;
      }

      .error {
        padding: 0.75rem;
        border: 1px solid #b00020;
        border-radius: 8px;
        color: #b00020;
        background: #fff0f2;
      }
    </style>
  </body>
</html>
