---
export const prerender = false;

import { isAdminRequest } from "../../../../lib/admin/auth";
import sections from "../../../../data/math/studySections.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const sortedSections = [...sections].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить PDF-материал — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/math/study/">← Учёба</a></p>
      <h1>Добавить PDF-материал</h1>

      {error && <p class="error">Ошибка: {error}</p>}

      {sortedSections.length > 0 ? (
        <form method="post" action="/api/admin/math/create-study-material" enctype="multipart/form-data">
          <label>
            Раздел
            <select name="sectionId" required>
              {sortedSections.map((section) => (
                <option value={section.id}>{section.titleRu}</option>
              ))}
            </select>
          </label>

          <label>
            Тип материала
            <select name="kind" required>
              <option value="theory">Теория</option>
              <option value="problems">Задачи</option>
              <option value="exam">Экзамен</option>
            </select>
          </label>

          <label>
            ID / slug
            <input name="id" required placeholder="cauchy-integral-formula" />
          </label>

          <label>
            Название RU
            <input name="titleRu" required />
          </label>

          <label>
            Title EN
            <input name="titleEn" required />
          </label>

          <label>
            Описание RU
            <textarea name="descriptionRu" rows="4" required></textarea>
          </label>

          <label>
            Description EN
            <textarea name="descriptionEn" rows="4" required></textarea>
          </label>

          <label>
            Дата
            <input name="date" type="date" required />
          </label>

          <label>
            PDF-файл
            <input name="pdf" type="file" accept="application/pdf" required />
          </label>

          <button type="submit">Добавить PDF-материал</button>
        </form>
      ) : (
        <p>Сначала добавь хотя бы один учебный раздел. Да, данные тоже требуют порядка, как ни странно.</p>
      )}
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 760px); margin: 3rem auto; }
      form { display: grid; gap: 1rem; }
      label { display: grid; gap: .35rem; }
      input, textarea, select { padding: .55rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #fffaf0; font: inherit; }
      button { padding: .65rem .9rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; cursor: pointer; }
      .error { padding: .75rem; border: 1px solid #b00020; border-radius: 8px; color: #b00020; background: #fff0f2; }
    </style>
  </body>
</html>
