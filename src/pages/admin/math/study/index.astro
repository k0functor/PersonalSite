---
export const prerender = false;

import { isAdminRequest } from "../../../../lib/admin/auth";
import sections from "../../../../data/math/studySections.json";
import materials from "../../../../data/math/studyMaterials.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const sortedSections = [...sections].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Учёба — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/math/">← Математика</a></p>
      <h1>Учёба</h1>

      <div class="actions">
        <a href="/admin/math/study/new-section/">Добавить раздел</a>
        <a href="/admin/math/study/new-material/">Добавить PDF-материал</a>
      </div>

      {sortedSections.length > 0 ? (
        <section class="list">
          {sortedSections.map((section) => {
            const count = materials.filter((item) => item.sectionId === section.id).length;
            return (
              <article class="card">
                <h2>{section.titleRu}</h2>
                <p>{section.descriptionRu}</p>
                <p class="meta">ID: {section.id} / материалов: {count}</p>
                <p><a href={`/ru/math/study/${section.id}/`} target="_blank">Открыть на сайте</a></p>
              </article>
            );
          })}
        </section>
      ) : (
        <p>Учебные разделы пока не добавлены.</p>
      )}
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 960px); margin: 3rem auto; }
      .actions { display: flex; flex-wrap: wrap; gap: .75rem; margin: 1.5rem 0; }
      .actions a { padding: .55rem .75rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; color: inherit; text-decoration: none; }
      .list { display: grid; gap: 1rem; }
      .card { padding: 1rem; border: 1px solid #cfc3b0; border-radius: 12px; background: #fffaf0; }
      .meta { color: #6f6a5f; font-family: monospace; }
    </style>
  </body>
</html>
