---
export const prerender = false;

import { isAdminRequest } from "../../../../lib/admin/auth";
import sections from "../../../../data/math/studySections.json";
import materials from "../../../../data/math/studyMaterials.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
const sortedSections = [...sections].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Учёба — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/math/">← Математика</a></p>
      <h1>Учёба</h1>

      <p>
        Учебные разделы и PDF-материалы. Каждый раздел на сайте содержит три направления: теория, задачи и экзамен.
      </p>

      {error && <p class="error">Ошибка: {error}</p>}
      {success && <p class="success">Готово: {success}</p>}

      <div class="actions">
        <a href="/admin/math/study/new-section/">Добавить раздел</a>
        <a href="/admin/math/study/new-material/">Добавить PDF-материал</a>
        <a href="/ru/math/study/" target="_blank">Открыть на сайте</a>
      </div>

      {sortedSections.length > 0 ? (
        <section class="list">
          {sortedSections.map((section) => {
            const count = materials.filter((item) => item.sectionId === section.id).length;
            return (
              <article class="card">
                <div class="top">
                  <div>
                    <h2>{section.titleRu}</h2>
                    <p>{section.descriptionRu}</p>
                  </div>

                  {count === 0 ? (
                    <form method="post" action="/api/admin/math/delete-study-section" onsubmit="return confirm('Удалить учебный раздел? Это действие изменит studySections.json в GitHub.');">
                      <input type="hidden" name="id" value={section.id} />
                      <button class="danger" type="submit">Удалить</button>
                    </form>
                  ) : (
                    <button class="disabled" type="button" disabled title="Нельзя удалить раздел с материалами">
                      Удалить нельзя
                    </button>
                  )}
                </div>

                <p class="meta">ID: {section.id} / материалов: {count} / порядок: {section.order ?? 999}</p>
                <p><a href={`/ru/math/study/${section.id}/`} target="_blank">Открыть раздел на сайте</a></p>
              </article>
            );
          })}
        </section>
      ) : (
        <p>Учебные разделы пока не добавлены.</p>
      )}
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 960px); margin: 3rem auto; }
      .actions { display: flex; flex-wrap: wrap; gap: .75rem; margin: 1.5rem 0; }
      .actions a { padding: .55rem .75rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; color: inherit; text-decoration: none; }
      .list { display: grid; gap: 1rem; }
      .card { padding: 1rem; border: 1px solid #cfc3b0; border-radius: 12px; background: #fffaf0; }
      .top { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; }
      h2 { margin-top: 0; }
      .meta { color: #6f6a5f; font-family: monospace; }
      button { padding: .45rem .7rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; cursor: pointer; }
      .danger { border-color: #b00020; color: #b00020; background: #fff0f2; }
      .disabled { color: #6f6a5f; cursor: not-allowed; opacity: .65; }
      .error { padding: .75rem; border: 1px solid #b00020; border-radius: 8px; color: #b00020; background: #fff0f2; }
      .success { padding: .75rem; border: 1px solid #2f5d50; border-radius: 8px; color: #2f5d50; background: #eef7f2; }
      @media (max-width: 640px) { .top { flex-direction: column; } }
    </style>
  </body>
</html>
