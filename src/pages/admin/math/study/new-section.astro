---
export const prerender = false;

import { isAdminRequest } from "../../../../lib/admin/auth";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Добавить учебный раздел — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/math/study/">← Учёба</a></p>
      <h1>Добавить учебный раздел</h1>

      {error && <p class="error">Ошибка: {error}</p>}

      <form method="post" action="/api/admin/math/create-study-section">
        <label>
          ID / slug
          <input name="id" required placeholder="complex-analysis" />
        </label>

        <label>
          Название RU
          <input name="titleRu" required placeholder="Комплексный анализ" />
        </label>

        <label>
          Title EN
          <input name="titleEn" required placeholder="Complex Analysis" />
        </label>

        <label>
          Описание RU
          <textarea name="descriptionRu" rows="4" required></textarea>
        </label>

        <label>
          Description EN
          <textarea name="descriptionEn" rows="4" required></textarea>
        </label>

        <label>
          Порядок сортировки
          <input name="order" type="number" value="100" />
        </label>

        <button type="submit">Добавить раздел</button>
      </form>
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 760px); margin: 3rem auto; }
      form { display: grid; gap: 1rem; }
      label { display: grid; gap: .35rem; }
      input, textarea { padding: .55rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #fffaf0; font: inherit; }
      button { padding: .65rem .9rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; cursor: pointer; }
      .error { padding: .75rem; border: 1px solid #b00020; border-radius: 8px; color: #b00020; background: #fff0f2; }
    </style>
  </body>
</html>
