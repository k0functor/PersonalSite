---
export const prerender = false;

import { isAdminRequest } from "../../../lib/admin/auth";
import iumSections from "../../../data/ium/sections.json";
import iumSheets from "../../../data/ium/sheets.json";
import books from "../../../data/math/books.json";
import studySections from "../../../data/math/studySections.json";
import studyMaterials from "../../../data/math/studyMaterials.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Математика — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/">← Админка</a></p>
      <h1>Математика</h1>

      <p>
        Управление математическим разделом: НМУ, книги и учёба.
      </p>

      <section class="grid">
        <a class="card" href="/admin/ium/">
          <h2>НМУ</h2>
          <p>Разделы и PDF-листочки. Разделов: {iumSections.length}, листочков: {iumSheets.length}.</p>
        </a>

        <a class="card" href="/admin/math/books/">
          <h2>Книги</h2>
          <p>Добавление и удаление книг. Сейчас в списке: {books.length}.</p>
        </a>

        <a class="card" href="/admin/math/study/">
          <h2>Учёба</h2>
          <p>Разделы с теорией, задачами и экзаменами. Разделов: {studySections.length}, материалов: {studyMaterials.length}.</p>
        </a>
      </section>
    </main>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f4ed;
        color: #181612;
      }

      .admin {
        width: min(100% - 2rem, 960px);
        margin: 3rem auto;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
      }

      .card {
        display: block;
        padding: 1rem;
        border: 1px solid #cfc3b0;
        border-radius: 12px;
        background: #fffaf0;
        color: inherit;
        text-decoration: none;
      }

      .card:hover {
        border-color: #2f5d50;
      }

      .card h2 {
        margin-top: 0;
      }

      .card p {
        color: #6f6a5f;
      }
    </style>
  </body>
</html>
