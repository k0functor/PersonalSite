---
export const prerender = false;

import { isAdminRequest } from "../../../../lib/admin/auth";
import books from "../../../../data/math/books.json";

const isAdmin = await isAdminRequest(Astro.cookies);

if (!isAdmin) {
  return Astro.redirect("/admin/login");
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
const sortedBooks = [...books].sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

const statusLabels = {
  read: "прочитал",
  reading: "читаю",
  planned: "планирую",
  paused: "отложил",
  reference: "справочник",
};
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Книги — Админка</title>
  </head>

  <body>
    <main class="admin">
      <p><a href="/admin/math/">← Математика</a></p>
      <h1>Книги</h1>

      <p>
        Управление списком математических книг: добавление и удаление.
      </p>

      {error && <p class="error">Ошибка: {error}</p>}
      {success && <p class="success">Готово: {success}</p>}

      <div class="actions">
        <a href="/admin/math/books/new/">Добавить книгу</a>
        <a href="/ru/math/books/" target="_blank">Открыть на сайте</a>
      </div>

      {sortedBooks.length > 0 ? (
        <section class="list">
          {sortedBooks.map((book) => (
            <article class="card">
              <div class="top">
                <div>
                  <h2>{book.title}</h2>
                  <p class="author">{book.author}</p>
                </div>

                <form method="post" action="/api/admin/math/delete-book" onsubmit="return confirm('Удалить книгу? Это действие изменит books.json в GitHub.');">
                  <input type="hidden" name="id" value={book.id} />
                  <button class="danger" type="submit">Удалить</button>
                </form>
              </div>

              <p>{book.commentRu}</p>
              <p class="meta">
                ID: {book.id} / статус: {statusLabels[book.status]} / область: {book.areaRu} / порядок: {book.order ?? 999}
              </p>
            </article>
          ))}
        </section>
      ) : (
        <p>Книги пока не добавлены.</p>
      )}
    </main>

    <style>
      body { margin: 0; font-family: system-ui, sans-serif; background: #f7f4ed; color: #181612; }
      .admin { width: min(100% - 2rem, 960px); margin: 3rem auto; }
      .actions { display: flex; flex-wrap: wrap; gap: .75rem; margin: 1.5rem 0; }
      .actions a { padding: .55rem .75rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; color: inherit; text-decoration: none; }
      .list { display: grid; gap: 1rem; }
      .card { padding: 1rem; border: 1px solid #cfc3b0; border-radius: 12px; background: #fffaf0; }
      .top { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; }
      h2 { margin: 0; }
      .author { margin-top: .25rem; color: #6f6a5f; }
      .meta { color: #6f6a5f; font-family: monospace; }
      button { padding: .45rem .7rem; border: 1px solid #cfc3b0; border-radius: 6px; background: #ebe1d0; cursor: pointer; }
      .danger { border-color: #b00020; color: #b00020; background: #fff0f2; }
      .error { padding: .75rem; border: 1px solid #b00020; border-radius: 8px; color: #b00020; background: #fff0f2; }
      .success { padding: .75rem; border: 1px solid #2f5d50; border-radius: 8px; color: #2f5d50; background: #eef7f2; }
      @media (max-width: 640px) { .top { flex-direction: column; } }
    </style>
  </body>
</html>
