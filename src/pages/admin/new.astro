---
export const prerender = false;

import { requireAdmin } from "../../lib/admin/auth";

const redirect = await requireAdmin(Astro.cookies);

if (redirect) {
  return redirect;
}

const defaultType = Astro.url.searchParams.get("type") ?? "math-ium";
const today = new Date().toISOString().slice(0, 10);

const defaultBody = `# New note

Write your content here.

Math instructions:
- Write formulas only inside the MDX content that this form creates.
- Use dollar delimiters for inline and display formulas.
- Do not use parenthesis or square-bracket LaTeX delimiters in MDX.
`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>New content — &lt;(.____.)&gt;</title>
  </head>

  <body>
    <main class="page">
      <header>
        <p class="logo">&lt;(.____.)&gt;</p>
        <h1>New content</h1>
        <p class="muted">
          This form creates an MDX file and commits it to GitHub. The admin page itself does not contain LaTeX formulas anymore, because apparently JSX sees braces and immediately chooses violence.
        </p>
      </header>

      <form method="post" action="/api/admin/create-content">
        <section class="card">
          <h2>Basic metadata</h2>

          <div class="grid">
            <label>
              Type
              <select name="type" id="type">
                <option value="math-ium" selected={defaultType === "math-ium"}>IUM solution</option>
                <option value="math-note" selected={defaultType === "math-note"}>Math note</option>
                <option value="programming-note" selected={defaultType === "programming-note"}>Programming note</option>
                <option value="game-devlog" selected={defaultType === "game-devlog"}>Game devlog</option>
                <option value="blog-post" selected={defaultType === "blog-post"}>Blog post</option>
              </select>
            </label>

            <label>
              Language
              <select name="lang">
                <option value="ru">Russian</option>
                <option value="en">English</option>
              </select>
            </label>

            <label>
              Date
              <input type="date" name="date" value={today} required />
            </label>

            <label>
              Slug
              <input name="slug" placeholder="algebraic-topology-sheet-02" />
            </label>
          </div>

          <label>
            Title
            <input name="title" required placeholder="Алгебраическая топология — листок 2" />
          </label>

          <label>
            Description
            <input name="description" required placeholder="Краткое описание материала." />
          </label>

          <label>
            Tags
            <input name="tags" placeholder="topology, ium, problem-sheet" />
          </label>
        </section>

        <section class="card optional ium-fields">
          <h2>IUM fields</h2>

          <div class="grid">
            <label>
              Course
              <input name="course" placeholder="Алгебраическая топология" />
            </label>

            <label>
              Sheet number
              <input type="number" name="sheetNumber" min="1" value="1" />
            </label>

            <label>
              Status
              <select name="status">
                <option value="not-started">not-started</option>
                <option value="in-progress" selected>in-progress</option>
                <option value="partly-solved">partly-solved</option>
                <option value="solved">solved</option>
                <option value="submitted">submitted</option>
                <option value="needs-rewrite">needs-rewrite</option>
              </select>
            </label>

            <label>
              Solved
              <input type="number" name="solved" min="0" value="0" />
            </label>

            <label>
              Total
              <input type="number" name="total" min="1" value="1" />
            </label>
          </div>
        </section>

        <section class="card optional topic-fields">
          <h2>Topic fields</h2>

          <div class="grid">
            <label>
              Topic
              <select name="topic">
                <option value="general">general</option>
                <option value="cpp">cpp</option>
                <option value="stl">stl</option>
                <option value="algorithms">algorithms</option>
                <option value="cs">cs</option>
                <option value="tools">tools</option>
                <option value="projects">projects</option>
              </select>
            </label>

            <label>
              Level
              <select name="level">
                <option value="basic">basic</option>
                <option value="intermediate">intermediate</option>
                <option value="advanced">advanced</option>
              </select>
            </label>

            <label>
              Game version
              <input name="version" placeholder="v0.1" />
            </label>
          </div>
        </section>

        <section class="card">
          <h2>Body</h2>

          <p class="hint">
            Put LaTeX only inside this textarea. The generated MDX file will handle it through the Markdown math pipeline. Use dollar delimiters for formulas. Avoid parenthesis and square-bracket LaTeX delimiters in MDX.
          </p>

          <label>
            MDX content
            <textarea name="body" rows="22">{defaultBody}</textarea>
          </label>
        </section>

        <div class="actions">
          <a href="/admin">Back</a>
          <button type="submit">Create MDX file</button>
        </div>
      </form>
    </main>

    <style>
      :root {
        --bg: #f7f4ed;
        --text: #181612;
        --muted: #6f6a5f;
        --border: #d8d0c2;
        --card: #fffaf0;
        --accent: #2f5d50;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      .page {
        width: min(100% - 2rem, 960px);
        margin-inline: auto;
        padding: 3rem 0;
      }

      .logo {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-weight: 700;
      }

      .muted {
        color: var(--muted);
      }

      .hint {
        padding: 0.85rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: white;
        color: var(--muted);
      }

      .card {
        padding: 1.25rem;
        margin-top: 1rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--card);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }

      label {
        display: grid;
        gap: 0.35rem;
        margin-top: 1rem;
      }

      input,
      select,
      textarea,
      button {
        font: inherit;
      }

      input,
      select,
      textarea {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: white;
      }

      textarea {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      .actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
      }

      button {
        padding: 0.8rem 1rem;
        border: 0;
        border-radius: 10px;
        background: var(--accent);
        color: white;
        cursor: pointer;
      }

      a {
        color: inherit;
      }
    </style>
  </body>
</html>
